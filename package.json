{
	"name": "monorepo",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "concurrently --kill-others --raw \"npm run dev --prefix web\"",
		"build": "concurrently --raw \"npm run build --prefix web\"",
		"start": "concurrently --kill-others --raw \"npm run start --prefix web\"",
		"lint": "concurrently --raw \"npm run lint --prefix web\""
	},
	"devDependencies": {
		"concurrently": "^9.2.1"
	},
	"workspaces": [
		"web"
	],
	"dependencies": {
		"@dataconnect/generated": "file:src/dataconnect-generated",
		"@supabase/supabase-js": "^2.105.4",
		"firebase": "^12.13.0",
		"vite": "^8.0.11"
	}
}
